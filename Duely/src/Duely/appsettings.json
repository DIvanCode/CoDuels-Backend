{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "DbConnection": {
    "ConnectionString": ""
  },
  "User": {
    "JwtToken": {
      "SecretKey": "",
      "ExpiresHours": 24,
      "IdClaim": "id"
    },
    "RefreshToken": {
      "ExpiresDays": 30
    },
    "WebSocketConnection": {
      "KeepAliveIntervalMs": 15000,
      "CloseTimeoutMs": 3000
    }
  },
  "IntegrationEvents": {
    "Processor": {
      "IntervalMs": 1000,
      "BatchSize": 100,
      "InitialNextProcessAttemptDelayMs": 50,
      "NextProcessAttemptDelayStepMs": 100,
      "MaxNextProcessAttemptDelayMs": 10000  
    }
  },
  "Duel": {
    "DefaultShouldShowOpponentSolution": true,
    "DefaultMaxDurationMinutes": 30,
    "DefaultTasksCount": 1,
    "DefaultTasksOrder": "Sequential"
  },
  "TournamentSynchronizationJob": {
    "CheckIntervalMs": 5000
  },
  "AnticheatBackgroundService": {
    "CheckIntervalMs": 10000,
    "ShouldCleanupUserActions": true
  },
  "DuelEndWatcherJob": {
    "CheckIntervalMs": 3000
  },
  "DuelMakingJob": {
    "CheckPairIntervalMs": 3000
  },
  "RateLimiting": {
    "SubmissionsPerMinute": 5,
    "RunsPerMinute": 10
  },
  "Taski": {
    "BaseUrl": "",
    "StatusUpdates": {
      "Mode": "rest",
      "Count": 20,
      "PollIntervalMs": 1000
    }
  },
  "Exesh": {
    "BaseUrl": "",
    "StatusUpdates": {
      "Mode": "rest",
      "Count": 20,
      "PollIntervalMs": 1000
    }
  },
  "Analyzer": {
    "BaseUrl": ""
  },
  "Kafka": {
    "BootstrapServers": "",
    "TaskiTopic": "taski.testing",
    "ExeshTopic": "exesh.step-updates",
    "GroupId": "duely",
    "SaslAuth": false
  },
  "Otel": {
    "IsEnabled": true,
    "ServiceName": "Duely",
    "MeterName": "Duely"
  }
}
