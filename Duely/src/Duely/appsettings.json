    "SubmissionsPerMinute": 5,
    "RunsPerMinute": 10
  },
  "Taski": {
    "BaseUrl": "",
    "StatusUpdates": {
      "Mode": "rest",
      "Count": 20,
      "PollIntervalMs": 1000
    }
  },
  "Exesh": {
    "BaseUrl": "",
    "StatusUpdates": {
      "Mode": "rest",
      "Count": 20,
      "PollIntervalMs": 1000
    }
  },
  "Analyzer": {
    "BaseUrl": ""
  },
  "Kafka": {
    "BootstrapServers": "",
    "TaskiTopic": "taski.testing",
    "ExeshTopic": "exesh.step-updates",
    "GroupId": "duely",
    "SaslAuth": false
  },
  "Otel": {
    "IsEnabled": true,
