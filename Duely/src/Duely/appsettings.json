    "CheckIntervalMs": 50,
    "InitialRetryDelayMs": 100,
    "MaxRetryDelayMs": 10000
  },
  "DuelEndWatcherJob": {
    "CheckIntervalMs": 3000
  },
  "DuelMakingJob": {
    "CheckPairIntervalMs": 3000
  },
  "JwtToken": {
    "SecretKey": "",
    "ExpiresHours": 24,
    "IdClaim": "id"
  },
