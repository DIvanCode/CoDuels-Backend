        "Level": 2
      },
      {
        "Rating": "900-1199",
        "Level": 3
      },
      {
        "Rating": "1200-1499",
        "Level": 4
      },
      {
        "Rating": "1500-1799",
        "Level": 5
      },
      {
        "Rating": "1800-2099",
        "Level": 6
      },
      {
        "Rating": "2100-2399",
        "Level": 7
      },
      {
        "Rating": "2400-2699",
        "Level": 8
      },
      {
        "Rating": "2700-2999",
        "Level": 9
      },
      {
        "Rating": "3000-9999",
        "Level": 10
      }
    ]
  },
  "DbConnection": {
    "ConnectionString": ""
  },
